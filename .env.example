# Public site URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MAIN_SITE_URL=https://www.krzacg.com
# Download CTA redirect target. Supports {slug}, {sourceId}, {title}
MAIN_SITE_GAME_URL_TEMPLATE=/?from=guide&slug={slug}

# Source content API
CONTENT_SOURCE_API_URL=https://www.krzacg.com
CONTENT_SOURCE_ASSET_BASE_URL=https://upload.krzacg.com
CONTENT_SYNC_PAGE_SIZE=10
CONTENT_SYNC_MAX_PAGES=3

# AI provider
AI_BASE_URL=https://xxxx.ai
AI_API_KEY=your-ai-api-key
AI_MODEL=your-default-model

# Model comparison script
AI_COMPARE_MODELS=model-a,model-b
# Optional: compare a specific generated game by slug from data/generated/games.json
AI_COMPARE_SLUG=
# Optional: compare custom input instead of a generated game
AI_COMPARE_TITLE=
AI_COMPARE_TAGS=
AI_COMPARE_SUMMARY=

# Scheduled rebuild — VERCEL_PROJECT_ID and VERCEL_ORG_ID are auto-injected by Vercel.
# Create a personal API token at https://vercel.com/account/tokens and set it here.
CRON_SECRET=replace-with-a-long-random-string
VERCEL_TOKEN=your-vercel-personal-api-token
